+static int Con_WordLength( const char *txt )
+{
+	assert( *txt );
+	int l = 0;
+	while ( *txt > ' ' ) {
+		if ( Q_IsColorString( txt ) ) {
+			txt += 2;
+		} else {
+			++l;
+			++txt;
+		}
+	}
+	return l;
+}
