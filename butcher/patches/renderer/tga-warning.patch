From: sOkam <7308253+heysokam@users.noreply.github.com>
Subject: [PATCH] Suppress top-down TGA warning in non-developer mode

Suppress top-down TGA warning in non-developer mode

Files: code/renderercommon/tr_image_tga.c

Co-authored-by: mediumBeast <74370030+mediumBeast@users.noreply.github.com>
---
diff --git a/code/renderercommon/tr_image_tga.c b/code/renderercommon/tr_image_tga.c
index ae7e85ad..1560a141 100644
--- a/code/renderercommon/tr_image_tga.c
+++ b/code/renderercommon/tr_image_tga.c
@@ -307,7 +307,7 @@ void R_LoadTGA ( const char *name, byte **pic, int *width, int *height)
 #endif
   // instead we just print a warning
   if (targa_header.attributes & 0x20) {
-    ri.Printf( PRINT_WARNING, "WARNING: '%s' TGA file header declares top-down image, ignoring\n", name);
+    ri.Printf( PRINT_DEVELOPER, "WARNING: '%s' TGA file header declares top-down image, ignoring\n", name);
   }
 
   if (width)

