From: sOkam <7308253+heysokam@users.noreply.github.com>
Subject: [PATCH] Console time display (date/time in console UI)

Depends on: timestamps.patch

Add con_timedisplay cvar (default 3, bitmask):
- Bit 1: show HH:MM:SS next to the input prompt
- Bit 2: show HH:MM:SS + YYYY-MM-DD in the console corner
Introduces Con_ResetFieldWidth to adjust input field width when time is shown.
Replaces all direct g_consoleField.widthInChars assignments with Con_ResetFieldWidth.

Files: code/client/cl_console.c, code/client/cl_keys.c, code/client/cl_main.c, code/client/client.h

---
diff --git a/code/client/cl_console.c b/code/client/cl_console.c
index 65f6242b..00000004 100644
--- a/code/client/cl_console.c
+++ b/code/client/cl_console.c
@@ -69,7 +69,9 @@ console_t	con;

 cvar_t		*con_conspeed;
 cvar_t		*con_autoclear;
 cvar_t		*con_notifytime;
 cvar_t		*con_scale;
+cvar_t		*con_timedisplay;
+static qboolean con_timedisplay_show = qfalse;

 int			g_console_field_width;

@@ -91,7 +93,7 @@ void Con_ToggleConsole_f( void ) {
 		Field_Clear( &g_consoleField );
 	}

-	g_consoleField.widthInChars = g_console_field_width;
+	Con_ResetFieldWidth();

 	Con_ClearNotify();
 	Key_SetCatcher( Key_GetCatcher() ^ KEYCATCH_CONSOLE );
@@ -317,7 +319,7 @@ void Con_CheckResize( void )
 		width = ((cls.glconfig.vidWidth / smallchar_width) - 2);

 		g_console_field_width = width;
-		g_consoleField.widthInChars = g_console_field_width;
+		Con_ResetFieldWidth();

 		if ( width > MAX_CONSOLE_WIDTH )
 			width = MAX_CONSOLE_WIDTH;
@@ -374,6 +376,25 @@ void Con_CheckResize( void )
 }


+/*
+==================
+Con_ResetFieldWidth
+==================
+*/
+void Con_ResetFieldWidth( void )
+{
+	g_consoleField.widthInChars = g_console_field_width -
+		(con_timedisplay && con_timedisplay->integer & 1 ? sizeof(con.prefix) : 0) -
+		(con_timedisplay && con_timedisplay->integer & 2 ? sizeof(con.prefix) + sizeof(con.date) : 0);
+	if ( g_consoleField.widthInChars <= 10 ) {
+		g_consoleField.widthInChars = g_console_field_width;
+		con_timedisplay_show = qfalse;
+	} else {
+		con_timedisplay_show = qtrue;
+	}
+}
+
+
@@ -393,7 +414,8 @@ void Con_Init( void )
 	con_conspeed = Cvar_Get( "scr_conspeed", "3", 0 );
 	Cvar_SetDescription( con_conspeed, "Console opening/closing scroll speed." );
+	con_timedisplay = Cvar_Get( "con_timedisplay", "3", CVAR_ARCHIVE_ND );
 	con_autoclear = Cvar_Get("con_autoclear", "1", CVAR_ARCHIVE_ND);
@@ -404,7 +426,7 @@ void Con_Init( void )
 	Cvar_SetDescription( con_scale, "Console font size scale." );

 	Field_Clear( &g_consoleField );
-	g_consoleField.widthInChars = g_console_field_width;
+	Con_ResetFieldWidth();

@@ -633,6 +655,7 @@ static void Con_DrawInput( void ) {
 	int		y;
+	int		offset = 0;

 	if ( cls.state != CA_DISCONNECTED && !(Key_GetCatcher( ) & KEYCATCH_CONSOLE ) ) {
 		return;
@@ -640,11 +663,16 @@ static void Con_DrawInput( void ) {

 	y = con.vislines - ( smallchar_height * 2 );

+	if ( con_timedisplay->integer & 1 && con_timedisplay_show ) {
+		offset = sizeof(con.prefix);
+		re.SetColor( g_color_table[ColorIndexFromChar('8')] );
+		SCR_DrawSmallString( con.xadjust + smallchar_width, y, con.prefix, sizeof(con.prefix) - 1 );
+	}
 	re.SetColor( con.color );

-	SCR_DrawSmallChar( con.xadjust + 1 * smallchar_width, y, ']' );
+	SCR_DrawSmallChar( con.xadjust + (offset + 1) * smallchar_width, y, ']' );

-	Field_Draw( &g_consoleField, con.xadjust + 2 * smallchar_width, y,
+	Field_Draw( &g_consoleField, con.xadjust + (offset + 2) * smallchar_width, y,
 		SCREEN_WIDTH - 3 * smallchar_width, qtrue, qtrue );
 }

@@ -810,6 +838,18 @@ static void Con_DrawSolidConsole( float frac ) {
 	SCR_DrawSmallString( cls.glconfig.vidWidth - ( ARRAY_LEN( Q3_VERSION ) ) * smallchar_width,
 		lines - smallchar_height, Q3_VERSION, ARRAY_LEN( Q3_VERSION ) - 1 );

+	if ( con_timedisplay->integer && con_timedisplay_show ) {
+		Con_UpdateDateTime();
+	}
+
+	// draw date and time
+	if ( con_timedisplay->integer & 2 && con_timedisplay_show ) {
+		SCR_DrawSmallString( cls.glconfig.vidWidth - (sizeof(con.prefix) + sizeof(con.date)) * smallchar_width,
+			lines - smallchar_height * 2, con.prefix, sizeof(con.prefix) - 1 );
+		SCR_DrawSmallString( cls.glconfig.vidWidth - sizeof(con.date) * smallchar_width,
+			lines - smallchar_height * 2, con.date, sizeof(con.date) - 1 );
+	}
+

diff --git a/code/client/cl_keys.c b/code/client/cl_keys.c
index 49a98dd5..00000004 100644
--- a/code/client/cl_keys.c
+++ b/code/client/cl_keys.c
@@ -424,7 +424,7 @@ static void Console_Key( int key ) {
 		Con_SaveField( &g_consoleField );

 		Field_Clear( &g_consoleField );
-		g_consoleField.widthInChars = g_console_field_width;
+		Con_ResetFieldWidth();

 		if ( cls.state == CA_DISCONNECTED ) {
@@ -444,14 +444,14 @@ static void Console_Key( int key ) {
 		 ( ( tolower(key) == 'p' ) && keys[K_CTRL].down ) ) {
 		Con_HistoryGetPrev( &g_consoleField );
-		g_consoleField.widthInChars = g_console_field_width;
+		Con_ResetFieldWidth();
 		return;
 	}

 		 ( ( tolower(key) == 'n' ) && keys[K_CTRL].down ) ) {
 		Con_HistoryGetNext( &g_consoleField );
-		g_consoleField.widthInChars = g_console_field_width;
+		Con_ResetFieldWidth();
 		return;
 	}

diff --git a/code/client/cl_main.c b/code/client/cl_main.c
index 9e23d282..00000004 100644
--- a/code/client/cl_main.c
+++ b/code/client/cl_main.c
@@ -3210,7 +3210,7 @@ static void CL_InitRenderer( void ) {
 	Con_CheckResize();

 	g_console_field_width = ((cls.glconfig.vidWidth / smallchar_width)) - 2;
-	g_consoleField.widthInChars = g_console_field_width;
+	Con_ResetFieldWidth();

diff --git a/code/client/client.h b/code/client/client.h
index e9e9dfc1..00000004 100644
--- a/code/client/client.h
+++ b/code/client/client.h
@@ -504,6 +504,7 @@ qboolean CL_ValidPakSignature( const byte *data, int len );
 extern cvar_t *con_scale;

 void Con_CheckResize( void );
+void Con_ResetFieldWidth( void );
 void Con_Init( void );
 void Con_Shutdown( void );

--
