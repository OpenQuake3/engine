From: sOkam <7308253+heysokam@users.noreply.github.com>
Subject: [PATCH] Fix Q_IsColorString treating ^<newline> as color codes

Q_IsColorString should not match ^<CR> or ^<LF> as color escape sequences,
as these corrupt console output when text contains ^ before line breaks.

Files: code/qcommon/q_shared.h
---
diff --git a/code/qcommon/q_shared.h b/code/qcommon/q_shared.h
index 8eb3dccd..ca92dd0d 100644
--- a/code/qcommon/q_shared.h
+++ b/code/qcommon/q_shared.h
@@ -459,7 +459,7 @@ extern	vec4_t		colorDkGrey;

 #define Q_COLOR_ESCAPE	'^'
-#define Q_IsColorString(p) ( *(p) == Q_COLOR_ESCAPE && *((p)+1) && *((p)+1) != Q_COLOR_ESCAPE )
+#define Q_IsColorString(p) ( *(p) == Q_COLOR_ESCAPE && *((p)+1) && *((p)+1) != Q_COLOR_ESCAPE && *((p)+1) != '\n' && *((p)+1) != '\r' )

 #define COLOR_BLACK		'0'
 #define COLOR_RED		'1'

--
