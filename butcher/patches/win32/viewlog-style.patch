From: sOkam <7308253+heysokam@users.noreply.github.com>
Subject: [PATCH] Win32 viewlog console colors and error box style

Win32 viewlog console colors and error box style

Files: code/win32/win_syscon.c

Co-authored-by: Jelle <jelle.vandeweyer@scarlet.be>
Co-authored-by: eugene <eugene@832414e2-6573-9c40-a513-caa1f8131539>
---
diff --git a/code/win32/win_syscon.c b/code/win32/win_syscon.c
index de8a5df4..95804311 100644
--- a/code/win32/win_syscon.c
+++ b/code/win32/win_syscon.c
@@ -53,13 +53,10 @@ Foundation, Inc., 51 Franklin St, Fifth Floor, Boston, MA  02110-1301  USA
 
 #define T TEXT
 
-#define EDIT_COLOR		RGB(0x00,0x00,0x10)
-#define TEXT_COLOR		RGB(0x40,0xEE,0x20)
+#define EDIT_COLOR		RGB(0x3C,0x3C,0x46)
+#define TEXT_COLOR		RGB(0xFF,0xFF,0xFF)
 
-#define ERROR_BG_COLOR	RGB(0x90,0x80,0x80)
-
-#define ERROR_COLOR_1   RGB(0xFF,0xFF,0x00)
-#define ERROR_COLOR_2   RGB(0xF0,0x00,0x00)
+#define ERROR_BG_COLOR	RGB(0xFF,0x00,0x00)
 
 static field_t console;
 
@@ -237,14 +234,12 @@ static LRESULT WINAPI ConWndProc( HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lP
 		{
 			if ( s_timePolarity & 1 )
 			{
-				SetBkColor( ( HDC ) wParam, ERROR_BG_COLOR );
-				SetTextColor( ( HDC ) wParam, ERROR_COLOR_1 );
-			}
-			else
-			{
-				SetBkColor( ( HDC ) wParam, ERROR_BG_COLOR );
-				SetTextColor( ( HDC ) wParam, ERROR_COLOR_2 );
+				SetBkColor( ( HDC ) wParam, EDIT_COLOR );
+				SetTextColor( ( HDC ) wParam, TEXT_COLOR );
+				return ( LRESULT ) s_wcd.hbrEditBackground;
 			}
+			SetBkColor( ( HDC ) wParam, ERROR_BG_COLOR );
+			SetTextColor( ( HDC ) wParam, TEXT_COLOR );
 			return ( LRESULT ) s_wcd.hbrErrorBackground;
 		}
 		break;

-- 
